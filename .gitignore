# ============================================
# Gradle
# ============================================
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Gradle build outputs
**/build/
**/out/

# Gradle caches
.gradle/
**/.gradle/

# ============================================
# IntelliJ IDEA
# ============================================
# User-specific files
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf/

# Ignore IDE settings EXCEPT code styles
.idea/*
!.idea/codeStyles
!.idea/codeStyles/*
!.idea/inspectionProfiles
!.idea/inspectionProfiles/*

# jOOQ generated sources
/build/generated/
/**/build/generated/

# Caches
*.iml
*.iws

# ============================================
# Kotlin / Java / Groovy
# ============================================
# Compiled class files
*.class

# Log files
*.log

# Temporary files
*.tmp
*.swp

# ============================================
# OS-specific
# ============================================
# macOS
.DS_Store

# Windows
Thumbs.db

